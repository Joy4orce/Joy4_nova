+     */
+    private Trakt.Result syncIncremental(int flag) {
+        log.debug("syncIncremental: starting incremental sync");
+        
+        try {
+            // Get last activity to determine what needs syncing
+            Trakt.Result lastActivityResult = mTrakt.getLastActivity();
+            if (lastActivityResult.status == Trakt.Status.ERROR_NETWORK) {
+                return handleSyncStatus(Trakt.Status.ERROR_NETWORK, flag, "getLastActivity");
+            }
+            
+            if (lastActivityResult.status == Trakt.Status.SUCCESS) {
+                LastActivities lastActivity = (LastActivities) lastActivityResult.obj;
+                
+                long lastWatchedSync = Trakt.getLastWatchedSync(mPreferences);
+                long lastPlaybackSync = Trakt.getLastPlaybackSync(mPreferences);
+                
+                // Check if we need to sync watched status
+                if (lastActivity.movies.watched_at.toEpochSecond() > lastWatchedSync ||
+                    lastActivity.episodes.watched_at.toEpochSecond() > lastWatchedSync) {
+                    
+                    log.debug("syncIncremental: syncing watched status from Trakt");
+                    OffsetDateTime sinceDate = OffsetDateTime.ofInstant(
+                        Instant.ofEpochSecond(lastWatchedSync), ZoneOffset.UTC);
+                    
+                    Trakt.Status status = syncWatchedStatusSince(sinceDate);
+                    if (status == Trakt.Status.ERROR_NETWORK) {
+                        return handleSyncStatus(status, flag, "syncWatchedStatusSince");
+                    }
+                    
+                    Trakt.setLastWatchedSync(mPreferences, getCurrentTraktTime());
+                }
+                
+                // Check if we need to sync playback status
+                if (Trakt.getSyncPlaybackPreference(mPreferences) &&
+                    (lastActivity.movies.paused_at.toEpochSecond() > lastPlaybackSync ||
+                     lastActivity.episodes.paused_at.toEpochSecond() > lastPlaybackSync)) {
+                    
+                    log.debug("syncIncremental: syncing playback status from Trakt");
+                    OffsetDateTime sinceDate = OffsetDateTime.ofInstant(
+                        Instant.ofEpochSecond(lastPlaybackSync), ZoneOffset.UTC);
+                    
+                    Trakt.Status status = syncPlaybackStatusSince(sinceDate);
+                    if (status == Trakt.Status.ERROR_NETWORK) {
+                        return handleSyncStatus(status, flag, "syncPlaybackStatusSince");
+                    }
+                    
+                    Trakt.setLastPlaybackSync(mPreferences, getCurrentTraktTime());
+                }
+            }
+            
+            // Always try to sync local changes to Trakt
+            Trakt.Status status = syncToTraktIncremental(flag);
+            if (status == Trakt.Status.ERROR_NETWORK) {
+                return handleSyncStatus(status, flag, "syncToTraktIncremental");
+            }
+            
+            log.debug("syncIncremental: completed successfully");
+            return handleSyncStatus(Trakt.Status.SUCCESS, flag, null);
+            
+        } catch (Exception e) {
+            log.error("syncIncremental: error during incremental sync", e);
+            return handleSyncStatus(Trakt.Status.ERROR, flag, "syncIncremental exception");
+        }
+    }
