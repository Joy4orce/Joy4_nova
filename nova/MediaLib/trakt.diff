+    // =============================================================================================
+    // Network Share Tracking Utilities
+    // =============================================================================================
+    
+    // Constant for network share preferences
+    private static final String NETWORK_SHARE_SCRAPED_PREFIX = "network_share_scraped_";
+    
+    /**
+     * Get the earliest scraped timestamp across all network shares to ensure proper delta sync
+     * This solves the multi-network-share problem where refreshing one share shouldn't
+     * invalidate delta sync for videos from other shares.
+     * 
+     * @param context Android context
+     * @return earliest timestamp across all network shares, or global timestamp if no shares found
+     */
+    public static long getEarliestNetworkShareScrapedUtc(Context context) {
+        SharedPreferences preferences = PreferenceManager.getDefaultSharedPreferences(context);
+        
+        // Get all network share timestamps
+        Map<String, ?> allPrefs = preferences.getAll();
+        long earliestTimestamp = Long.MAX_VALUE;
+        boolean foundNetworkShares = false;
+        
+        for (Map.Entry<String, ?> entry : allPrefs.entrySet()) {
+            String key = entry.getKey();
+            if (key.startsWith(NETWORK_SHARE_SCRAPED_PREFIX) && entry.getValue() instanceof Long) {
+                long timestamp = (Long) entry.getValue();
+                if (timestamp < earliestTimestamp) {
+                    earliestTimestamp = timestamp;
+                }
+                foundNetworkShares = true;
+            }
+        }
+        
+        // If no network shares found, fall back to global timestamp
+        if (!foundNetworkShares) {
+            return getLastTimeVideoScrapedUtc(context);
+        }
+        
+        return earliestTimestamp == Long.MAX_VALUE ? 0L : earliestTimestamp;
+    }
+    
+    /**
+     * Get the last time any video was scraped (global timestamp)
+     */
+    public static long getLastTimeVideoScrapedUtc(Context context) {
+        SharedPreferences preferences = PreferenceManager.getDefaultSharedPreferences(context);
+        return preferences.getLong(AutoScrapeService.PREFERENCE_LAST_TIME_VIDEO_SCRAPED_UTC, 0L);
+    }
+
+    /**
+     * Extract network share identifier from a file URI
+     * Examples: smb://server/share -> smb_server_share, ftp://host/path -> ftp_host
+     */
+    public static String extractNetworkShareId(String fileUri) {
+        if (fileUri == null) return null;
+        
+        try {
+            Uri uri = Uri.parse(fileUri);
+            String scheme = uri.getScheme();
+            
+            if (scheme == null || (!scheme.equals("smb") && !scheme.equals("ftp") && 
+                                   !scheme.equals("sftp") && !scheme.equals("upnp") && 
+                                   !scheme.equals("webdav") && !scheme.equals("ftps"))) {
+                return null; // Not a network share
+            }
+            
+            String host = uri.getHost();
+            if (host == null) return null;
+            
+            // For SMB, include share name for more granular tracking
+            if (scheme.equals("smb")) {
+                String path = uri.getPath();
+                if (path != null && path.length() > 1) {
+                    String[] pathParts = path.substring(1).split("/");
+                    if (pathParts.length > 0 && !pathParts[0].isEmpty()) {
+                        return scheme + "_" + host + "_" + pathParts[0];
+                    }
+                }
+            }
+            
+            return scheme + "_" + host;
+        } catch (Exception e) {
+            return null;
+        }
+    }
+
+    /**
+     * Update the last scraped timestamp for a specific network share
+     */
+    public static void updateNetworkShareScrapedTimestamp(Context context, String shareId, long timestamp) {
+        if (shareId == null) return;
+        
+        SharedPreferences preferences = PreferenceManager.getDefaultSharedPreferences(context);
+        preferences.edit()
+            .putLong(NETWORK_SHARE_SCRAPED_PREFIX + shareId, timestamp)
+            .apply();
+    }
+
+    /**
+     * Get the last scraped timestamp for a specific network share
+     */
+    public static long getNetworkShareScrapedTimestamp(Context context, String shareId) {
+        if (shareId == null) return 0L;
+        
+        SharedPreferences preferences = PreferenceManager.getDefaultSharedPreferences(context);
+        return preferences.getLong(NETWORK_SHARE_SCRAPED_PREFIX + shareId, 0L);
+    }
+
 }
