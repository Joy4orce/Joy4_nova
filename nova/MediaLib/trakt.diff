+    /**
+     * Enhanced playback processing with multi-device conflict resolution
+     * @param videos List of PlaybackResponse from Trakt
+     * @return Status of the operation
+     */
+    private Trakt.Status processPlaybackResponsesWithConflictResolution(List<PlaybackResponse> videos) {
+        log.debug("processPlaybackResponsesWithConflictResolution: processing {} videos", videos.size());
+        
+        final ContentResolver cr = getContentResolver();
+        
+        for (PlaybackResponse video : videos) {
+            try {
+                String whereClause;
+                if (video.movie != null) {
+                    whereClause = VideoStore.Video.VideoColumns._ID + " IN (" +
+                            "SELECT video_id FROM movie WHERE " + 
+                            VideoStore.Video.VideoColumns.SCRAPER_M_ONLINE_ID + "= " + video.movie.ids.tmdb + ")";
+                } else if (video.episode != null) {
+                    whereClause = VideoStore.Video.VideoColumns._ID + " IN (" +
+                            "SELECT video_id FROM episode WHERE " + 
+                            VideoStore.Video.VideoColumns.SCRAPER_E_ONLINE_ID + "= " + video.episode.ids.tmdb + ")";
+                } else {
+                    continue; // Skip if neither movie nor episode
+                }
+                
+                Cursor cursor = cr.query(VideoStore.Video.Media.EXTERNAL_CONTENT_URI, 
+                                       VideoDbInfo.COLUMNS, whereClause, null, null);
+                
+                if (cursor != null && cursor.moveToFirst()) {
+                    VideoDbInfo localVideo = VideoDbInfo.fromCursor(cursor, false);
+                    cursor.close();
+                    
+                    if (localVideo != null) {
+                        processVideoConflictResolution(localVideo, video);
+                    }
+                }
+                
+            } catch (Exception e) {
+                log.error("processPlaybackResponsesWithConflictResolution: error processing video", e);
+            }
+        }
+        
+        return Trakt.Status.SUCCESS;
+    }
+
+    /**
+     * Smart conflict resolution for a single video
+     * @param localVideo local video information
+     * @param traktVideo Trakt video information
+     */
+    private void processVideoConflictResolution(VideoDbInfo localVideo, PlaybackResponse traktVideo) {
+        log.debug("processVideoConflictResolution: resolving conflicts for {}", localVideo.scraperTitle);
+        
+        long traktLastPlayed = traktVideo.paused_at != null ? traktVideo.paused_at.toEpochSecond() : 0;
+        double traktProgress = traktVideo.progress;
+        int traktResumePercent = (int) Math.round(traktProgress);
+        int traktResumeTime = (int) (traktProgress / 100.0 * localVideo.duration);
+        
+        ContentValues values = new ContentValues();
+        boolean shouldUpdate = false;
+        
+        // Multi-device conflict resolution strategy:
+        
+        // 1. If Trakt was played more recently, use Trakt data
+        if (traktLastPlayed > localVideo.lastTimePlayed) {
+            log.debug("processVideoConflictResolution: Trakt is more recent, updating from Trakt");
+            values.put(VideoStore.Video.VideoColumns.ARCHOS_LAST_TIME_PLAYED, traktLastPlayed);
+            
+            if (traktProgress > 0 && traktResumeTime > localVideo.resume && localVideo.resume != -2) {
+                values.put(VideoStore.Video.VideoColumns.ARCHOS_TRAKT_RESUME, traktResumePercent);
+                values.put(VideoStore.Video.VideoColumns.BOOKMARK, traktResumeTime);
+                
+                if (traktResumePercent >= Trakt.SCROBBLE_THRESHOLD) {
+                    values.put(VideoStore.Video.VideoColumns.ARCHOS_TRAKT_SEEN, 1);
+                    values.put(VideoStore.Video.VideoColumns.BOOKMARK, -2); // Fully watched
+                }
+            }
+            shouldUpdate = true;
+        }
+        // 2. If local was played more recently but Trakt has higher progress, merge intelligently
+        else if (localVideo.lastTimePlayed > traktLastPlayed && 
+                 traktProgress > Math.abs(localVideo.traktResume) && 
+                 localVideo.resume != -2) {
+            
+            log.debug("processVideoConflictResolution: Local is more recent but Trakt has higher progress, merging");
+            // Keep local timestamp but consider Trakt progress if significantly higher
+            if (traktResumeTime > localVideo.resume + (localVideo.duration * 0.1)) { // 10% difference threshold
+                values.put(VideoStore.Video.VideoColumns.ARCHOS_TRAKT_RESUME, traktResumePercent);
+                values.put(VideoStore.Video.VideoColumns.BOOKMARK, traktResumeTime);
+                shouldUpdate = true;
+            }
+        }
+        // 3. If both have similar timestamps, prefer the higher progress
+        else if (Math.abs(traktLastPlayed - localVideo.lastTimePlayed) < 300 && // 5 minute tolerance
+                 traktProgress > Math.abs(localVideo.traktResume)) {
+            
+            log.debug("processVideoConflictResolution: Similar timestamps, using higher progress");
+            values.put(VideoStore.Video.VideoColumns.ARCHOS_TRAKT_RESUME, traktResumePercent);
+            values.put(VideoStore.Video.VideoColumns.BOOKMARK, traktResumeTime);
+            shouldUpdate = true;
+        }
+        
+        if (shouldUpdate) {
+            getContentResolver().update(VideoStore.Video.Media.EXTERNAL_CONTENT_URI,
+                    values, VideoStore.Video.VideoColumns._ID + " = " + localVideo.id, null);
+            log.debug("processVideoConflictResolution: Updated local video with resolved data");
+        }
+    }
