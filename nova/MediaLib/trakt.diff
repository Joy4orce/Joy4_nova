+    /**
+     * Get last video activity timestamp from device database
+     * @return UTC timestamp of last video activity, or 0 if none found
+     */
+    private long getLastDeviceVideoActivity() {
+        try {
+            android.database.Cursor cursor = getContentResolver().query(
+                VideoStore.Video.Media.EXTERNAL_CONTENT_URI,
+                new String[]{VideoStore.Video.VideoColumns.ARCHOS_LAST_TIME_PLAYED},
+                VideoStore.Video.VideoColumns.ARCHOS_LAST_TIME_PLAYED + " > 0",
+                null,
+                VideoStore.Video.VideoColumns.ARCHOS_LAST_TIME_PLAYED + " DESC LIMIT 1"
+            );
+            
+            if (cursor != null && cursor.moveToFirst()) {
+                long lastActivity = cursor.getLong(0);
+                cursor.close();
+                return lastActivity;
+            }
+            if (cursor != null) cursor.close();
+        } catch (Exception e) {
+            log.warn("getLastDeviceVideoActivity: error querying database", e);
+        }
+        return 0;
+    }
