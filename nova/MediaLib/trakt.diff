+    /**
+     * Enhanced full sync detection that incorporates device activity timestamps and network share scenarios
+     * @return true if full sync is needed
+     */
+    private boolean isEnhancedFullSyncNeeded() {
+        // Start with basic full sync detection
+        boolean basicFullSyncNeeded = Trakt.isFullSyncNeeded(mPreferences);
+        if (basicFullSyncNeeded) {
+            return true;
+        }
+        
+        // Enhanced logic: check device activity vs last sync times
+        try {
+            long lastPlaybackSync = Trakt.getLastPlaybackSync(mPreferences);
+            long lastWatchedSync = Trakt.getLastWatchedSync(mPreferences);
+            
+            // Get last video activity from device
+            long lastDeviceActivity = getLastDeviceVideoActivity();
+            
+            // Network share scenario: check if any network shares have been refreshed since last sync
+            // This addresses the multi-network-share problem described in design notes
+            long earliestNetworkShareScraped = MediaUtils.getEarliestNetworkShareScrapedUtc(this);
+            long lastGlobalScrape = MediaUtils.getLastTimeVideoScrapedUtc(this);
+            
+            // If global scrape timestamp is newer than earliest network share timestamp,
+            // it means some shares have been refreshed more recently than others.
+            // In this case, we need full sync to ensure we don't miss videos from network shares
+            // that were refreshed before the most recent share refresh.
+            if (lastGlobalScrape > earliestNetworkShareScraped && 
+                (lastGlobalScrape > lastPlaybackSync || lastGlobalScrape > lastWatchedSync)) {
+                log.debug("isEnhancedFullSyncNeeded: network share refresh detected, full sync needed to avoid missing videos");
+                return true;
+            }
+            
+            // If device has been active since last sync, consider incremental sync sufficient
+            // But if it's been a long time since last sync, force full sync
+            if (lastDeviceActivity > lastPlaybackSync || lastDeviceActivity > lastWatchedSync) {
+                long currentTime = System.currentTimeMillis() / 1000L;
+                long dayInSeconds = 24 * 60 * 60;
+                
+                // If last sync was more than 24 hours ago and device has been active, do full sync
+                if (currentTime - Math.max(lastPlaybackSync, lastWatchedSync) > dayInSeconds) {
+                    log.debug("isEnhancedFullSyncNeeded: device active since last sync and sync is old, full sync needed");
+                    return true;
+                }
+            }
+        } catch (Exception e) {
+            log.warn("isEnhancedFullSyncNeeded: error checking device activity, defaulting to basic sync logic", e);
+        }
+        
+        return false;
+    }
