+    private Trakt.Status processPlaybackStatusFromTrakt(Trakt.Result result) {
+        log.debug("processPlaybackStatusFromTrakt: processing playback status data with conflict resolution");
+        
+        if (result.objType == Trakt.Result.ObjectType.MOVIES && result.obj != null) {
+            List<PlaybackResponse> videos = (List<PlaybackResponse>) result.obj;
