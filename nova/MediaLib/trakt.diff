+    public static boolean isFullSyncNeeded(SharedPreferences preferences) {
+        long lastFullSync = getLastFullSync(preferences);
+        long lastPlaybackSync = getLastPlaybackSync(preferences);
+        long lastWatchedSync = getLastWatchedSync(preferences);
+        
+        // Full sync needed if:
+        // 1. Never done a full sync
+        // 2. Last full sync was more than a week ago
+        // 3. Any of the individual sync timestamps are 0 (indicating partial sync failure)
+        
+        if (lastFullSync == 0) {
+            return true;
+        }
+        
+        long currentTime = System.currentTimeMillis() / 1000L;
+        long weekInSeconds = 7 * 24 * 60 * 60;
+        
+        if (currentTime - lastFullSync > weekInSeconds) {
+            return true;
+        }
+        
+        if (lastPlaybackSync == 0 || lastWatchedSync == 0) {
+            return true;
+        }
+        
+        return false;
+    }
