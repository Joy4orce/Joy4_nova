<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:card_view="http://schemas.android.com/apk/res-auto"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:layout_width="match_parent"
	card_view:cardCornerRadius="12dp"
	android:layout_height="wrap_content"
	>

	<LinearLayout
		android:id="@+id/file_info_content"
		android:animateLayoutChanges="true"
		android:layout_width="fill_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:gravity="left"

		>
		<TextView android:id="@+id/file_info_header"
			android:layout_width="fill_parent"
			android:text="@string/info_file"
			android:layout_height="wrap_content"
			style="@style/VideoInfoFileInfo.CardViewTitle"/>
		<LinearLayout
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:gravity="left"
			android:paddingLeft="@dimen/video_info_margin_simple"
			android:paddingRight="@dimen/video_info_margin_simple"
			android:paddingTop="@dimen/video_info_margin_half"
			android:paddingBottom="@dimen/video_info_margin_half">


			<TextView android:id="@+id/file_name"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:textSize="@dimen/video_info_medium_text"
				android:singleLine="false"/>

			<TextView android:id="@+id/file_path"
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:textSize="@dimen/video_info_small_text"
				android:alpha="0.7"
				android:singleLine="false"
				android:ellipsize="end"/>

			<TextView
				android:id="@+id/file_error"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				style="@style/VideoInfoFileInfo"
				android:paddingTop="@dimen/video_info_margin_half"
				android:singleLine="false"
				android:text="@string/file_access_error"
				android:textColor="@color/error_text_over_blue_background"
				/>

			<LinearLayout
				android:layout_width="fill_parent"
				android:layout_height="wrap_content"
				android:paddingTop="@dimen/video_info_margin_half"
				android:orientation="horizontal">

				<TextView
					android:id="@+id/duration"
					style="@style/VideoInfoFileInfo"

					android:layout_marginRight="50dip"/>

				<TextView
					android:id="@+id/filesize"
					style="@style/VideoInfoFileInfo"
					android:layout_marginLeft="10dip"/>
			</LinearLayout>

			<!-- Progress Spinner VideoMetaData -->
			<include
				layout="@layout/audio_video_info_processing"
				android:id="@+id/audio_video_info_processing"
				android:visibility="visible" />

			<!-- VideoMetaData Info Layout -->
			<include
				layout="@layout/audio_video_info2"
				android:id="@+id/audio_video_info"
				android:visibility="visible" />

			<TableRow
				android:id="@+id/technical_display_info_row"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dip"
				android:visibility="gone">
				<ImageView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginRight="12dip"
					android:layout_marginTop="0dip"
					app:srcCompat="@drawable/ic_display_settings_24" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/technical_info"
						style="@style/VideoInfoFileInfo"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="start"
						android:singleLine="false"
						android:textAlignment="viewStart" />
				</LinearLayout>
			</TableRow>

			<TableRow
				android:id="@+id/technical_hdmi_info_row"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dip"
				android:visibility="gone">
				<ImageView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginRight="12dip"
					android:layout_marginTop="0dip"
					app:srcCompat="@drawable/ic_settings_input_hdmi_24" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/technical_hdmi_info"
						style="@style/VideoInfoFileInfo"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="start"
						android:singleLine="false"
						android:textAlignment="viewStart" />
				</LinearLayout>
			</TableRow>

			<TableRow
				android:id="@+id/technical_mediacodec_info_row"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dip"
				android:visibility="gone">
				<ImageView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginRight="12dip"
					android:layout_marginTop="0dip"
					app:srcCompat="@drawable/ic_surround_sound_24" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/technical_mediacodec_info"
						style="@style/VideoInfoFileInfo"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="start"
						android:singleLine="false"
						android:textAlignment="viewStart" />
				</LinearLayout>
			</TableRow>

			<TableRow
				android:id="@+id/technical_spatialization_info_row"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="16dip"
				android:visibility="gone">
				<ImageView
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:layout_marginRight="12dip"
					android:layout_marginTop="0dip"
					app:srcCompat="@drawable/ic_spatial_audio_24" />

				<LinearLayout
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:orientation="vertical">
					<TextView
						android:id="@+id/technical_spatialization_info"
						style="@style/VideoInfoFileInfo"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:gravity="start"
						android:singleLine="false"
						android:textAlignment="viewStart" />
				</LinearLayout>
			</TableRow>

		</LinearLayout>
	</LinearLayout>

</androidx.cardview.widget.CardView>
